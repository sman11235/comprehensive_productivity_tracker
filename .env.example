# Copy this file to `.env` before running `docker compose up --build`.

# Core service settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUTH_API_HOST=0.0.0.0
AUTH_API_PORT=8000
LOCATION_API_HOST=0.0.0.0
LOCATION_API_PORT=8001
AGENT_TIMEZONE=America/New_York

# GitHub producer
GITHUB_USERNAME=
GITHUB_TOKEN=
DEV_DEVICE_ID=github-producer
GITHUB_STATE_FILE=python-producers/.state/github.json
GITHUB_EVENT_LIMIT=30

# Plaid producer and auth API
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ACCESS_TOKEN=
PLAID_BASE_URL=https://sandbox.plaid.com
PLAID_STATE_FILE=python-producers/.state/plaid.json
PLAID_COUNT=100
PLAID_CLIENT_NAME=Productivity Tracker
PLAID_COUNTRY_CODES=US
PLAID_PRODUCTS=transactions
PLAID_LANGUAGE=en
PLAID_DEFAULT_USER_ID=local-user
PLAID_REDIRECT_URI=http://localhost:8000/
PLAID_SANDBOX_INSTITUTION_ID=ins_109508
PLAID_SANDBOX_USERNAME=user_transactions_dynamic
PLAID_SANDBOX_PASSWORD=pass_good
TXN_DEVICE_ID=plaid-producer

# Location API database connection
# Leave POSTGRES_DSN empty to use the individual POSTGRES_* values below.
POSTGRES_DSN=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=personal_foundry
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_SSLMODE=prefer

# Optional OpenAI-backed agent settings for /agent/query and /agent/user-summary
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=
